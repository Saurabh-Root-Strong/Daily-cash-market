# Copy this file to .streamlit/secrets.toml for LOCAL testing of cloud mode.
# In Streamlit Community Cloud, set these in the app settings → Secrets section.
# NEVER commit secrets.toml to git (it is in .gitignore).

# ── Cloud mode flag ─────────────────────────────────────────────────────────
CLOUD_MODE = "true"

# ── GitHub Releases (for DuckDB snapshot download) ──────────────────────────
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (or contents:read for private repos)
GITHUB_TOKEN = "ghp_your_token_here"

# Repository that holds the latest-data release with market.duckdb.gz
# Can be a separate public repo (then GITHUB_TOKEN is optional for downloads)
# Example: "saurabh-diwaker22/nse-market-data"
GITHUB_REPO  = "your-username/your-data-repo"
